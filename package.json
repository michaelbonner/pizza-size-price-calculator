		"typescript-eslint": "^8.59.4",
		"vite": "^8.0.13",
		"vitest": "^4.1.6"
	},
	"type": "module",
	"dependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@tabler/icons-svelte": "^3.44.0",
		"@tailwindcss/vite": "^4.3.0",
		"clsx": "^2.1.1"
	}
}
